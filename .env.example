# agent-itau — variaveis de ambiente
# Copie para .env.local e ajuste

# Identificacao do usuario (opcional, usado nos relatorios)
SQUAD_USER_NAME="Seu Nome"
SQUAD_USER_EMAIL="seuemail@itau.com.br"

# Diretorio dos projetos-alvo (onde os agentes vao trabalhar)
PROJECTS_ROOT="$HOME/projetos"

# Raiz do agent-itau (opcional). Por padrao se auto-resolve a partir da
# localizacao dos scripts e do dashboard, entao funciona em qualquer pasta
# onde voce clonar o repo. Defina apenas se rodar de um diretorio diferente.
# AGENT_ITAU_ROOT="$HOME/agent-itau"

# Dashboard
DASHBOARD_PORT=3000

# Integracoes opt-in
# Para ativar, descomente E crie o arquivo .claude/integracoes/{nome}.md
# JIRA_HOST=
# JIRA_TOKEN=
# GITHUB_TOKEN=
# SLACK_WEBHOOK=
# SONARQUBE_HOST=
# SONARQUBE_TOKEN=
